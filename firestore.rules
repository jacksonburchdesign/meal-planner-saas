rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the current user's familyId
    function getUserFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // users collection
    match /users/{userId} {
      // User can only read and write their own user document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // families collection
    match /families/{familyId} {
      // Allow public read; primarily for fetching theme and basic info needed for unauth PWA loading on subdomains.
      // E.g., `where("subdomain_slug", "==", subdomain)`
      allow read: if true; 
      
      // Allow creation by any authenticated user
      allow create: if isAuthenticated();
      
      // Only authenticated members of the family can update or delete
      allow update, delete: if isAuthenticated() && getUserFamilyId() == familyId;
    }

    // recipes collection
    match /recipes/{recipeId} {
      allow read, update, delete: if isAuthenticated() && resource.data.familyId == getUserFamilyId();
      // Allow create only if the incoming document's familyId matches the user's familyId
      allow create: if isAuthenticated() && request.resource.data.familyId == getUserFamilyId();
    }

    // weeklyMeals collection (was erroneously weekly_plans)
    match /weeklyMeals/{planId} {
      allow read, update, delete: if isAuthenticated() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuthenticated() && request.resource.data.familyId == getUserFamilyId();
    }

    // pinterestImports collection
    match /pinterestImports/{importId} {
      allow read, update, delete: if isAuthenticated() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuthenticated() && request.resource.data.familyId == getUserFamilyId();
    }

    // mealHistory collection
    // mealHistory collection
    match /mealHistory/{historyId} {
      allow read, update, delete: if isAuthenticated() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuthenticated() && request.resource.data.familyId == getUserFamilyId();
    }

    // familyConnections collection
    match /familyConnections/{connectionId} {
      allow read, delete: if isAuthenticated() && (resource.data.fromFamilyId == getUserFamilyId() || resource.data.toFamilyId == getUserFamilyId());
      // Create and update managed primarily via Cloud Functions for approval workflows, but allow basic access if needed
      allow create, update: if isAuthenticated() && (request.resource.data.fromFamilyId == getUserFamilyId() || request.resource.data.toFamilyId == getUserFamilyId());
    }

    // sharedRecipes collection
    match /sharedRecipes/{sharedId} {
      allow read, delete: if isAuthenticated() && (resource.data.fromFamilyId == getUserFamilyId() || resource.data.targetFamilyId == getUserFamilyId());
      allow create, update: if isAuthenticated() && (request.resource.data.fromFamilyId == getUserFamilyId() || request.resource.data.targetFamilyId == getUserFamilyId());
    }

    // notifications collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuthenticated() && request.resource.data.familyId == getUserFamilyId();
    }
  }
}
